{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "server:dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "cross-env NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "start": "npx expo start",
    "test": "tsx tests/hallucination.test.ts && tsx tests/skill-routing.test.ts && tsx tests/skill-confidence.test.ts && tsx tests/skill-e2e.test.ts && tsx tests/craft-generation.test.ts && tsx tests/rag-pipeline.test.ts && tsx tests/verification-engine.test.ts && tsx tests/truth-engine-v2.test.ts && tsx tests/builder.test.ts && tsx tests/phase-checklist.test.ts",
