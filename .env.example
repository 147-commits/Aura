# ─── Required ─────────────────────────────────────────────────────────────────

# Standard Postgres connection string. Works with Render, Railway, Fly,
# AWS RDS, Neon, Supabase, local Docker, etc.
DATABASE_URL=postgres://user:password@host:5432/aura

# Used to derive the AES-256-GCM key for encrypting messages and memories
# at rest. Must be at least 32 bytes of entropy. Rotate carefully — old
# rows become unreadable after rotation.
SESSION_SECRET=

# At least one AI provider key is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (full URL or bare host).
# Example: https://app.example.com,https://staging.example.com
CORS_ORIGINS=

# ─── Optional ─────────────────────────────────────────────────────────────────

# Override the OpenAI base URL (proxy, Azure-compatible endpoint, etc.).
# OPENAI_BASE_URL=

# Postgres tuning. Defaults: max=10, idle=10000ms, connect=10000ms.
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=10000
# DB_CONNECTION_TIMEOUT_MS=10000

# Force SSL on/off for Postgres. Defaults: on in production, off otherwise.
# PGSSL=true

# Public domain for static Expo bundle deployment (used by scripts/build.js).
# EXPO_PUBLIC_DOMAIN=
